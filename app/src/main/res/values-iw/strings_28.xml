    <string name="supported_formula_syntax" formatted="false">
        <![CDATA[
        <title>תחביר נתמך</title> <br>
        <minor>positive &ensp; p &ensp; negative &ensp; n</minor> <br>
        &ensp; מצייני מקום שיוחלפו בספירות הדירוגים בפועל. <br>
        <minor>+ &ensp; - &ensp; * &ensp; /</minor> <br>
        &ensp; פעולות מתמטיות בסיסיות (N/0=N) <br>
        <minor>%</minor> <br>
        &ensp; אחוז <br>
        <minor>&lt; &ensp; &gt; &ensp; &lt;= &ensp; &gt;=</minor> <br>
        &ensp; השוואות <br>
        <minor>& &ensp; |</minor> <br>
        &ensp; AND/OR לוגי <br>
        <minor>( &ensp; )</minor> <br>
        &ensp; סוגריים <br>
        <br>
        <b>דוגמאות</b> <br>
        &ensp; <sample>negative &gt; positive</sample> <br>
        &ensp; <sample>P - N &gt; 5</sample> (לא תלוי רישיות) <br>
        &ensp; <sample>p &gt; 3 & n &gt; 2 & (n / p &gt;= 120%)</sample> <br>
        ]]>
    </string>
